,"taskCount":0,"tasks":[]},{"id":5904,"type":"Product Backlog Item","title":"3. US-Modal de visualización de datos básicos de candidato","state":"New","areaPath":"ODI\\ODI Team Tecnologia","iterationPath":"ODI","assignedTo":"","description":"","acceptanceCriteria":"","taskCount":0,"tasks":[]},{"id":5905,"type":"Product Backlog Item","title":"2. HdU-Búsqueda de persona por set de datos mínimos","state":"Committed","areaPath":"ODI\\ODI Team Asistencial","iterationPath":"ODI\\R-01\\Sprint 03","assignedTo":"Geroan Antonio Cadenas Alvarez","description":"<div style=\"margin:0px;font-family:&quot;Segoe UI&quot;, &quot;Segoe UI Web&quot;, Arial, Verdana, sans-serif;font-size:12px;\"><div style=\"margin:0px;clear:both;cursor:text;\"><p style=\"margin:0px 0px 10.6667px;font-weight:normal;color:windowtext;text-align:left;\"><span lang=ES-AR style=\"margin:0px;font-size:11pt;font-family:Aptos, Aptos_EmbeddedFont, Aptos_MSFontService, sans-serif;font-weight:bold;\"><span style=\"margin:0px;\">Como</span></span><span lang=ES-AR style=\"margin:0px;font-size:11pt;font-family:Aptos, Aptos_EmbeddedFont, Aptos_MSFontService, sans-serif;\"><span style=\"margin:0px;\">: Usuario de sistema ODI</span></span><span style=\"margin:0px;font-size:11pt;font-family:Aptos, Aptos_EmbeddedFont, Aptos_MSFontService, sans-serif;\">&nbsp;</span> </p> </div><div style=\"margin:0px;clear:both;cursor:text;\"><p style=\"margin:0px 0px 10.6667px;font-weight:normal;color:windowtext;text-align:left;\"><span lang=ES-AR style=\"margin:0px;font-size:11pt;font-family:Aptos, Aptos_EmbeddedFont, Aptos_MSFontService, sans-serif;font-weight:bold;\"><span style=\"margin:0px;\">Quiero</span></span><span lang=ES-AR style=\"margin:0px;font-size:11pt;font-family:Aptos, Aptos_EmbeddedFont, Aptos_MSFontService, sans-serif;\"><span style=\"margin:0px;\">: Realizar búsqueda de candidatos</span></span><span style=\"margin:0px;font-size:11pt;font-family:Aptos, Aptos_EmbeddedFont, Aptos_MSFontService, sans-serif;\">&nbsp;</span> </p> </div><div style=\"margin:0px;clear:both;cursor:text;\"><p style=\"margin:0px 0px 10.6667px;font-weight:normal;color:windowtext;text-align:left;\"><span lang=ES-AR style=\"margin:0px;font-size:11pt;font-family:Aptos, Aptos_EmbeddedFont, Aptos_MSFontService, sans-serif;font-weight:bold;\"><span style=\"margin:0px;\">Para</span></span><span lang=ES-AR style=\"margin:0px;font-size:11pt;font-family:Aptos, Aptos_EmbeddedFont, Aptos_MSFontService, sans-serif;\"><span style=\"margin:0px;\">: Realizar selección o empadronamiento de personas</span></span><span style=\"margin:0px;font-size:11pt;font-family:Aptos, Aptos_EmbeddedFont, Aptos_MSFontService, sans-serif;\">&nbsp;</span> </p> </div><div style=\"margin:0px;clear:both;cursor:text;\"><p style=\"margin:0px 0px 10.6667px;font-weight:normal;color:windowtext;text-align:left;\"><span lang=ES-AR style=\"margin:0px;font-size:11pt;font-family:Aptos, Aptos_EmbeddedFont, Aptos_MSFontService, sans-serif;\"><span style=\"margin:0px;\"></span></span><span style=\"margin:0px;font-size:11pt;font-family:Aptos, Aptos_EmbeddedFont, Aptos_MSFontService, sans-serif;\">&nbsp;</span> </p> </div><div style=\"margin:0px;clear:both;cursor:text;\"><p style=\"margin:14px 0px 8px;font-weight:normal;color:windowtext;text-align:justify;\"><span lang=ES-AR style=\"margin:0px;font-size:11pt;text-decoration:underline;font-family:Aptos, Aptos_EmbeddedFont, Aptos_MSFontService, sans-serif;font-weight:bold;\"><span style=\"margin:0px;\">Descripción y comportamiento</span></span><span lang=ES-AR style=\"margin:0px;font-size:11pt;font-family:Aptos, Aptos_EmbeddedFont, Aptos_MSFontService, sans-serif;font-weight:bold;\"><span style=\"margin:0px;\">:</span></span><span lang=ES-AR style=\"margin:0px;font-size:11pt;font-family:Aptos, Aptos_EmbeddedFont, Aptos_MSFontService, sans-serif;\"><span style=\"margin:0px;\"> </span><span style=\"margin:0px;\">Desde el </span><span style=\"margin:0px;\">módulo</span><span style=\"margin:0px;\"> identificatorio de personas, luego de realizar búsqueda por tipo y numero de documento, si el sistema no arroja candidatos,</span><span style=\"margin:0px;\"> o si </span><span style=\"margin:0px;\">s</span><span style=\"margin:0px;\">elecciona el botón de “Búsqueda por set mínimo”</span><span style=\"margin:0px;\">, </span><span style=\"margin:0px;\">el </span><span style=\"margin:0px;\">sistema</span><span style=\"margin:0px;\"> desplegará campos para una</span><span style=\"margin:0px;\"> búsqueda ampliada</span><span style=\"margin:0px;\"> por “set de datos mínimos”</span><span style=\"margin:0px;\"> (</span></span><a href=\"https://xd.adobe.com/view/b8af0d29-cf96-4eca-a665-2f27192aeb58-edfc/screen/419cff06-194e-479f-853e-c5d82d17a113\" target=_blank rel=\"noreferrer noopener\" style=\"margin:0px;\"><span lang=ES-AR style=\"margin:0px;color:rgb(0, 0, 255);font-size:11pt;text-decoration:underline;font-family:Aptos, Aptos_EmbeddedFont, Aptos_MSFontService, sans-serif;\"><span style=\"margin:0px;\">pantalla 1</span></span></a><span lang=ES-AR style=\"margin:0px;font-size:11pt;font-family:Aptos, Aptos_EmbeddedFont, Aptos_MSFontService, sans-serif;\"><span style=\"margin:0px;\">)</span><span style=\"margin:0px;\">.</span><span style=\"margin:0px;\"> </span><span style=\"margin:0px;\">Se usarán TODOS los datos del set de datos mínimo para buscar los candidatos</span><span style=\"margin:0px;\">,</span><span style=\"margin:0px;\"> es esencial comprender que estos datos no son excluyentes entre sí. En lugar de buscar coincidencias exactas para todos los datos simultáneamente, se calcularán porcentajes de coincidencia para cada dato individualmente. Esto permite una búsqueda más flexible y precisa, considerando diferentes grados de coincidencia para cada campo.</span></span><span style=\"margin:0px;font-size:11pt;font-family:Aptos, Aptos_EmbeddedFont, Aptos_MSFontService, sans-serif;\">&nbsp;</span> </p> </div><div style=\"margin:0px;clear:both;cursor:text;\"><p style=\"margin:14px 0px 8px;font-weight:normal;color:windowtext;text-align:left;\"><span lang=ES-AR style=\"margin:0px;font-size:11pt;font-family:Aptos, Aptos_EmbeddedFont, Aptos_MSFontService, sans-serif;\"><span style=\"margin:0px;\"></span></span><span style=\"margin:0px;font-size:11pt;font-family:Aptos, Aptos_EmbeddedFont, Aptos_MSFontService, sans-serif;\">&nbsp;</span> </p> </div><div style=\"margin:0px;clear:both;cursor:text;\"><p style=\"margin:0px 0px 10.6667px;font-weight:normal;color:windowtext;text-align:justify;\"><span lang=ES-AR style=\"margin:0px;font-size:11pt;font-family:Aptos, Aptos_EmbeddedFont, Aptos_MSFontService, sans-serif;\"></span><span style=\"margin:0px;font-size:11pt;font-family:WordVisiCarriageReturn_MSFontService, Aptos, Aptos_EmbeddedFont, Aptos_MSFontService, sans-serif;\"><span style=\"margin:0px;\">&nbsp;</span></span><span lang=ES-AR style=\"text-align:left;margin:0px;font-size:11pt;font-family:Aptos, Aptos_EmbeddedFont, Aptos_MSFontService, sans-serif;font-weight:bold;\"><span style=\"margin:0px;\">Set de datos </span><span style=\"margin:0px;\">mínimos</span><span style=\"margin:0px;\">:</span></span><span style=\"text-align:left;margin:0px;font-size:11pt;font-family:Aptos, Aptos_EmbeddedFont, Aptos_MSFontService, sans-serif;\">&nbsp;</span> </p> </div><ul><li style=\"clear:both;cursor:text;font-size:11pt;font-family:Aptos, Aptos_MSFontService, sans-serif;\"><p style=\"margin:0px;font-weight:normal;color:windowtext;text-align:left;\"><span lang=ES-AR style=\"margin:0px;font-family:Aptos, Aptos_EmbeddedFont, Aptos_MSFontService, sans-serif;\"><span style=\"margin:0px;\">Tipo de documento</span><span style=\"margin:0px;\"> </span></span><span lang=ES-AR style=\"margin:0px;font-family:Aptos, Aptos_EmbeddedFont, Aptos_MSFontService, sans-serif;font-weight:bold;\"><span style=\"margin:0px;\">(</span><span style=\"margin:0px;background-position:0px 100%;background-repeat:repeat-x;border-bottom:1px solid transparent;\">select</span><span style=\"margin:0px;\">)</span><span style=\"margin:0px;\"> (traer datos de </span><span style=\"margin:0px;\">búsqueda</span><span style=\"margin:0px;\">)</span></span><span style=\"margin:0px;font-family:Aptos, Aptos_EmbeddedFont, Aptos_MSFontService, sans-serif;\">&nbsp;</span> </p> </li><li style=\"clear:both;cursor:text;font-size:11pt;font-family:Aptos, Aptos_MSFontService, sans-serif;\"><p style=\"margin:0px;font-weight:normal;color:windowtext;text-align:left;\"><span lang=ES-AR style=\"margin:0px;font-family:Aptos, Aptos_EmbeddedFont, Aptos_MSFontService, sans-serif;\"><span style=\"margin:0px;\">Numero de documento</span><span style=\"margin:0px;\"> (</span></span><span lang=ES-AR style=\"margin:0px;font-family:Aptos, Aptos_EmbeddedFont, Aptos_MSFontService, sans-serif;font-weight:bold;\"><span style=\"margin:0px;\">campo de texto libre)</span><span style=\"margin:0px;\"> (traer datos de búsqueda)</span></span><span style=\"margin:0px;font-family:Aptos, Aptos_EmbeddedFont, Aptos_MSFontService, sans-serif;\">&nbsp;</span> </p> </li><li style=\"clear:both;cursor:text;font-size:11pt;font-family:Aptos, Aptos_MSFontService, sans-serif;\"><p style=\"margin:0px;font-weight:normal;color:windowtext;text-align:justify;\"><span lang=ES-AR style=\"margin:0px;font-family:Aptos, Aptos_EmbeddedFont, Aptos_MSFontService, sans-serif;\"><span style=\"margin:0px;\">Nombre </span></span><span lang=ES-AR style=\"margin:0px;font-family:Aptos, Aptos_EmbeddedFont, Aptos_MSFontService, sans-serif;font-weight:bold;\"><span style=\"margin:0px;\">(campo de texto libre</span><span style=\"margin:0px;\">)</span></span><span style=\"margin:0px;font-family:Aptos, Aptos_EmbeddedFont, Aptos_MSFontService, sans-serif;\">&nbsp;</span> </p> </li><li style=\"clear:both;cursor:text;font-size:11pt;font-family:Aptos, Aptos_MSFontService, sans-serif;\"><p style=\"margin:0px;font-weight:normal;color:windowtext;text-align:justify;\"><span lang=ES-AR style=\"margin:0px;font-family:Aptos, Aptos_EmbeddedFont, Aptos_MSFontServi