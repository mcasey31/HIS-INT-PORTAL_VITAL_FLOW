ox-sizing:border-box;font-family:&quot;Segoe UI&quot;, &quot;Segoe UI Web&quot;, Arial, Verdana, sans-serif;font-size:12px;margin:0px 0px 10.6667px;color:windowtext;text-align:left;\"><span style=\"font-family:Aptos, Aptos_EmbeddedFont, Aptos_MSFontService, sans-serif;font-size:11pt;\"><span style=\"cursor:pointer;\"><u><a href=\"https://xd.adobe.com/view/a4b6825b-0469-4a3f-9a1f-f8ea0c6d4b48-f1e5/screen/16e650ec-8086-41c7-9a43-7520fdd618eb/\">Pantalla 3:</a></u></span>&nbsp;Grilla de l<span style=\"display:inline !important;\">istado<span>&nbsp;</span></span><span style=\"box-sizing:border-box;display:inline !important;\">de bloque de programación</span></span> </p><p style=\"box-sizing:border-box;font-family:&quot;Segoe UI&quot;, &quot;Segoe UI Web&quot;, Arial, Verdana, sans-serif;font-size:12px;margin:0px 0px 10.6667px;color:windowtext;text-align:left;\"><span style=\"font-family:Aptos, Aptos_EmbeddedFont, Aptos_MSFontService, sans-serif;font-size:11pt;\"><span style=\"box-sizing:border-box;display:inline !important;\"><a href=\"https://xd.adobe.com/view/a4b6825b-0469-4a3f-9a1f-f8ea0c6d4b48-f1e5/screen/16e650ec-8086-41c7-9a43-7520fdd618eb/\">Pantalla 4:</a>&nbsp;<span style=\"display:inline !important;\">Grilla de l</span><span style=\"box-sizing:border-box;display:inline !important;\">istado<span style=\"box-sizing:border-box;\">&nbsp;</span></span><span style=\"box-sizing:border-box;display:inline !important;\">de bloque de programación (visualización de íconos visualizar, editar y menú contextual)</span></span></span> </p><div style=\"box-sizing:border-box;font-family:&quot;Segoe UI&quot;, &quot;Segoe UI Web&quot;, Arial, Verdana, sans-serif;font-size:12px;margin:0px 0px 10.6667px;color:windowtext;text-align:left;\"><br> </div><div style=\"box-sizing:border-box;font-family:&quot;Segoe UI&quot;, &quot;Segoe UI Web&quot;, Arial, Verdana, sans-serif;font-size:12px;margin:0px 0px 10.6667px;color:windowtext;text-align:left;\"><span style=\"box-sizing:border-box;font-family:Aptos, Aptos_EmbeddedFont, Aptos_MSFontService, sans-serif;font-size:14.6667px;display:inline !important;\"><br></span> </div><p style=\"box-sizing:border-box;font-family:&quot;Segoe UI&quot;, &quot;Segoe UI Web&quot;, Arial, Verdana, sans-serif;font-size:12px;margin:0px 0px 10.6667px;color:windowtext;text-align:left;\"> </p><p style=\"box-sizing:border-box;font-family:&quot;Segoe UI&quot;, &quot;Segoe UI Web&quot;, Arial, Verdana, sans-serif;font-size:12px;margin:0px 0px 10.6667px;color:windowtext;text-align:left;\"><span style=\"font-family:Aptos, Aptos_EmbeddedFont, Aptos_MSFontService, sans-serif;font-size:11pt;\"><b style=\"box-sizing:border-box;font-size:14px;text-align:start;\"><b style=\"box-sizing:border-box;\">DER<a href=\"https://dbdiagram.io/d/Agendas-67a69d0b263d6cf9a070191b\" style=\"box-sizing:border-box;text-decoration:underline;cursor:pointer;\">&nbsp;Diagrama de agendas - dbdiagram.io</a></b></b><br></span> </p><p style=\"box-sizing:border-box;font-family:&quot;Segoe UI&quot;, &quot;Segoe UI Web&quot;, Arial, Verdana, sans-serif;font-size:12px;margin:0px 0px 10.6667px;color:windowtext;text-align:left;\"><span style=\"font-family:Aptos, Aptos_EmbeddedFont, Aptos_MSFontService, sans-serif;font-size:11pt;\"><b style=\"box-sizing:border-box;font-size:14px;text-align:start;\"><br></b></span> </p> </div> </div></span></font> </div> </div><div style=\"box-sizing:border-box;font-size:14px;text-align:start;\"> </div> </div> </div></span> </div><br>","acceptanceCriteria":"<ul><li>Si a la agenda no&nbsp;se le han configurado los bloques de programación, en la grilla se visualizara un mensaje como indica el mockoup&nbsp;&nbsp; </li><li><span>Al&nbsp; &quot;Guardar&quot; en el alta de agenda, sólo quedarán activos los botones/íconos de ver detalle,&nbsp; editar o copiar según sea el caso, en la grilla de bloques de programación.&nbsp;</span> </li> </ul>","taskCount":13,"tasks":[{"id":11546,"type":"Task","title":"Estructura de HU","state":"Done","assignedTo":"Geroan Antonio Cadenas Alvarez","description":"<div>Estructura de HU<br> </div><div><br> </div><div> </div>"},{"id":13408,"type":"Test Case","title":"QA - Verificar tooltips","state":"Ready","assignedTo":"Hernan Alexis Gutierrez","description":""},{"id":12548,"type":"Task","title":"FE - Maquetado de la grilla","state":"Done","assignedTo":"Marco Alex Brusa","description":""},{"id":13409,"type":"Bug","title":"QA -  Bloques de programación/ tooltip \"Días\" y distancia entre columnas","state":"Done","assignedTo":"Hernan Alexis Gutierrez","description":""},{"id":13267,"type":"Bug","title":"QA - Estado de Agenda modo creado con bloques de programación activo","state":"New","assignedTo":"Sebastian Mario Baudracco","description":""},{"id":12595,"type":"Task","title":"QA - Creación de casos de prueba","state":"Done","assignedTo":"Hernan Alexis Gutierrez","description":""},{"id":12588,"type":"Task","title":"BE - Code Review","state":"Done","assignedTo":"German Facundo Skrobak","description":""},{"id":11545,"type":"Task","title":"Análisis Funcional","state":"Done","assignedTo":"Geroan Antonio Cadenas Alvarez","description":"<div>Análisis Funcional <br> </div><div><br> </div><div> </div>"},{"id":12596,"type":"Task","title":"QA - Ejecución de casos de prueba","state":"Done","assignedTo":"Hernan Alexis Gutierrez","description":""},{"id":12549,"type":"Task","title":"FE - Integración de grilla","state":"Done","assignedTo":"Marco Alex Brusa","description":""},{"id":12667,"type":"Test Case","title":"QA -  Verificar orden de visualización por bloque","state":"Ready","assignedTo":"Hernan Alexis Gutierrez","description":""},{"id":12550,"type":"Task","title":"BE - Endpoint lista de bloques de programación","state":"Done","assignedTo":"Lucas Ezequiel Ayala","description":""},{"id":12447,"type":"Task","title":"Diseño - Grilla de bloque de programación","state":"To Do","assignedTo":"Diego Alejandro Nuñez","description":""}]},{"id":7021,"type":"Product Backlog Item","title":"Edición de bloques de programación variable","state":"New","areaPath":"ODI\\ODI Team Asistencial","iterationPath":"ODI","assignedTo":"Martin Miguel Diaz Maffini","description":"<div><b>Como:&nbsp;</b>&nbsp;Gestor de agendas. </div><div><b>Quiero:</b> Editar una programación horaria </div><div><b>Para:</b> Modificar la configuración de un bloque de programación.&nbsp; </div><div><br> </div><div><b>Descripción y comportamiento</b>: Desde la edición de la agenda, tendrá la opción en el marco de bloque programación, para editarlo ingresando desde el menú contextual o de la ventana de detalle, siempre y cuando el bloque este activo.&nbsp;&nbsp; </div><div><br> </div><div><img src=\"https://dev.azure.com/SofreDigital/23856a9c-f820-4746-ac02-b8afbe8dd3e1/_apis/wit/attachments/5a8011a9-92c4-4375-b939-b583a2fdc6e1?fileName=image.png\" alt=Image><br> </div><div>&nbsp; </div><div>Para editar algunas configuraciones de dicho bloque, se limitara algunos datos que no podrán ser afectados en el proceso de la modificación. A los que se les permitirá la edición, se mencionan a continuación:&nbsp; </div><div><br> </div><div><b>Datos no permitidos editar:</b> </div><div><ul><li>Tipo de bloque de programación </li><li>Fecha desde.&nbsp;<span style=\"display:inline !important;\">(No permite, si la fecha a editar es menor o igual a la fecha del día de la edición)</span> </li> </ul> </div><div><b style=\"box-sizing:border-box;\">Datos que se permitirán la editar:</b><br> </div><div><ul><li><span style=\"box-sizing:border-box;\">Nombre de la programación.</span> </li><li><span style=\"box-sizing:border-box;\">Fecha hasta (<b>Ver nota de casos posibles</b>)</span> </li><li><span style=\"box-sizing:border-box;\"><span style=\"box-sizing:border-box;\">Fecha desde. (Se puede editar, si la fecha a editar es mayor&nbsp;<span style=\"box-sizing:border-box;display:inline !important;\">a la fecha del día de la edición, osea se creo la agenda a futuro y no ha sido puesta en actividad</span>)</span><br></span> </li><li><span style=\"box-sizing:border-box;\">Seleccionar Días de asignación de turnos.<br></span> </li><li><span style=\"box-sizing:border-box;\">Hora desde</span> </li><li><span style=\"box-sizing:border-box;\">Hora Hasta</span> </li><li><span style=\"box-sizing:border-box;\">Lugar de atención</span> </li><li><span style=\"box-sizing:border-box;\">Frecuencia</span> </li><li><span style=\"box-sizing:border-box;\">Turnos secuenciales</span> </li><li><span style=\"box-sizing:border-box;\">Prácticas médicas.&nbsp;<span style=\"display:inline !important;\">Se podrán eliminar o agregar prácticas al bloque, considerando al menos una práctica para poder guardar.</span></span> </li><li><span style=\"box-sizing:border-box;\">Gestión de cupos.&nbsp;</span> </li> </ul><div><br> </div><div><img src=\"https://dev.azure.com/SofreDigital/23856a9c-f820-4746-ac02-b8afbe8dd3e1/_apis/wit/attachments/04e6abe5-a33f-4b56-87ee-58e2d10db0a0?fileName=image.png\" alt=Image style=\"box-sizing:border-box;max-width:100%;align-self:center;\"><br> </div> </div><div><span><br></span> </div><div><span>En el caso de prácticas y gestión de cupos, se podrán agregar o quitar de la programación las prácticas ya definidas y quitar reglas de cupos ya configurados y/o crear nuevas reglas.</span> </div><div><span><br></span> </div><div><span><img src=\"https://dev.azure.com/SofreDigital/23856a9c-f820-4746-ac02-b8afbe8dd3e1/_apis/wit/attachments/3444fbf3-bd5f-4ad8-b7e4-b7f1ec6c0383?fileName=image.png\" alt=Image><br></span> </div><div><br> </div><div><b></b> </div><div style=\"box-sizing:border-box;font-weight:400;\"><b style=\"box-sizing:border-box;font-weight:bolder;\">Nota de casos posibles en la modificación datos que afecten a los turnos agendados:</b> </div><div style=\"box-sizing:border-box;font-weight:400;\">1)<span style=\"box-sizing:border-box;\">&nbsp;</span><b style=\"box-sizing:border-box;font-weight:bolder;\">Extensión de la fecha, hora, días, frecuencia del bloque, a una fecha futura</b>.&nbsp; </div><div style=\"box-sizing:border-box;font-weight:400;\">&nbsp; &nbsp; &nbsp; En este primer caso, el flujo no genera ningún inconveniente ni validación con respecto a los slots que se encuentren activos, se permite la extensión del bloque hasta la fecha que se indique, hasta la fecha indicada, se crearán nuevos slot de acuerdo a los días establecidos en el bloque.&nbsp; </div><div style=\"box-sizing:border-box;font-weight:400;\">2)<span style=\"box-sizing:border-box;\">&nbsp;</span><b style=\"box-sizing:border-box;font-weight:bolder;\">Reducción de la fecha<span style=\"box-sizing:border-box;\">&nbsp;</span><span style=\"box-sizing:border-box;display:inline !important;\">hasta, hora desde, hora hasta, frecuencia&nbsp;&nbsp;</span>a una fecha hasta mayor a la actual.&nbsp;</b> </div><div style=\"box-sizing:border-box;font-weight:400;\"><b style=\"box-sizing:border-box;font-weight:bolder;\">&nbsp; &nbsp;</b><span style=\"box-sizing:border-box;\">&nbsp;</span>&nbsp;En el caso de reducción de la vigencia del bloque, se debe validar las siguientes condiciones: si el bloque tenía slots activos y asignados<span style=\"box-sizing:border-box;\">&nbsp;</span><span style=\"box-sizing:border-box;display:inline !important;\">a turnos,&nbsp;</span>se cancelarán los turnos de los pacientes pasándolas a un estado por reasignar y los slot ocupados quedarán en estado de bloqueados.&nbsp;<span style=\"box-sizing:border-box;display:inline !important;\"><span style=\"box-sizing:border-box;\">&nbsp;</span>En el caso de que los slot estén activos y libres serán bloqueados para que no queden disponibles para ser asignado.&nbsp;</span> </div><div style=\"box-sizing:border-box;font-weight:400;\"><span style=\"box-sizing:border-box;\">3)&nbsp;</span><b style=\"box-sizing:border-box;font-weight:bolder;\">Reducción de la fecha&nbsp;hasta, a una fecha menor a la actual.&nbsp;</b> </div><div style=\"box-sizing:border-box;font-weight:400;\"><span style=\"box-sizing:border-box;display:inline !important;\">&nbsp; &nbsp; &nbsp; &nbsp; En el caso de que la fecha hasta sea menor a la fecha actual, no se permitirá la edición de la misma.&nbsp;</span> </div><div style=\"box-sizing:border-box;font-weight:400;\"><span style=\"box-sizing:border-box;display:inline !important;\"><br style=\"box-sizing:border-box;\"></span> </div><div style=\"box-sizing:border-box;font-weight:400;\"><span style=\"box-sizing:border-box;display:inline !important;\">Resumen:&nbsp; al momento de realizar cualquier cambio en la configuración del bloque de programación que afecte a la definición de un slot, los mismos deben ser revisados en cuanto a si tienen asociado un turno y eventualmente reprogramarlo.</span> </div><div><span style=\"box-sizing:border-box;display:inline !important;\"></span> </div><div><span style=\"box-sizing:border-box;display:inline !important;\"><br></span> </div><div><span style=\"box-sizing:border-box;display:inline !important;\"><a href=\"https://xd.adobe.com/view/7281821b-7083-4c60-8728-bf3dcde84523-27d2/screen/800a2ca4-fcae-440a-b611-7c8544b6ca3a/\">https://xd.adobe.com/view/7281821b-7083-4c60-8728-bf3dcde84523-27d2/screen/800a2ca4-fcae-440a-b611-7c8544b6ca3a/</a><br></span> </div><div><span style=\"box-sizing:border-box;display:inline !important;\"><br></span> </div><div><br> </div><div> </div>","acceptanceCriteria":"<ul><li>Se debe respetar las condiciones de datos permitidos y no permitidos a la hora de editar el bloque de programación.&nbsp;<span style=\"display:inline !important;\">Se debe considerar las reglas explicadas para el campo fecha desde.&nbsp;</span> </li><li>Se debe alertar antes de eliminar algunas practica médica, Ver <a href=\"https://xd.adobe.com/view/7281821b-7083-4c60-8728-bf3dcde84523-27d2/screen/538178ce-8195-4d8f-b2a1-82be3b7fd577\">pantalla 3&nbsp;</a> </li><li>En el caso de cortar la vigencia del bloque, se debe validar si los slot afectados han sido asignados, de ser así se deben cancelar los turnos al pacientes, y cambiar el estado tanto de los turnos como del slot como se indica en la HU </li><li>No debe permitir guardar la edición de la configuración si esta no cuenta con al menos una practica medica asociada.<br> </li><li>Al editar dar el mensaje de éxito<br> </li> </ul>","taskCount":4,"tasks":[{"id":15354,"type":"Task","title":"Ajuste de HU","state":"Done","assignedTo":"Manuel Rolando Alvarez","description":""},{"id":16615,"type":"Task","title":"DT - interfaces","state":"Done","assignedTo":"Diego Alejandro Nuñez","description":""},{"id":11459,"type":"Task","title":"Escritura de HU","state":"Done","assignedTo":"Geroan Antonio Cadenas Alvarez","description":"<div>Escritura de HU<br> </div><div><br> </div><div><span>Se creo los diseños de diagramas de casos de usos, secuencia y DER de la HU<br></span><span></span><br> </div><div> </div>"},{"id":11456,"type":"Task","title":"Análisis funcional","state":"Done","assignedTo":"Geroan Antonio Cadenas Alvarez","description":"<div><span>Para el análisis de esta HU interactuó el equipo de asistencial Martín Casey (coordina el equipo), y los analistas, &nbsp;Sebastián, Natalia y Geroan. <br></span><span></span><br> </div>"}]},{"id":7027,"type":"Product Backlog Item","title":"Agregar Bloques de programación fija","state":"Done","areaPath":"ODI\\ODI Team Asistencial","iterationPath":"ODI\\R-01\\Sprint 19","assignedTo":"Brian Ezequiel Agüero","description":"<div style=\"box-sizing:border-box;\"><p style=\"margin:0cm 0cm 8pt;font-size:11pt;font-family:Aptos, sans-serif;\"><b>Como: </b><span lang=ES-AR style=\"box-sizing:border-box;color:windowtext;margin:0px;font-family:Aptos, Aptos_EmbeddedFont, Aptos_MSFontService, sans-serif;\"><span style=\"box-sizing:border-box;margin:0px;\"><b style=\"box-sizing:border-box;\"><span style=\"box-sizing:border-box;\">&nbsp;G</span></b></span></span><span lang=ES-AR style=\"box-sizing:border-box;color:windowtext;margin:0px;font-family:Aptos, Aptos_EmbeddedFont, Aptos_MSFontService, sans-serif;\"><span style=\"box-sizing:border-box;margin:0px;\">estor de agendas.&nbsp;</span></span> </p><p style=\"margin:0cm 0cm 8pt;font-size:11pt;font-family:Aptos, sans-serif;\"><b>Quiero: </b>Crear programación horaria </p><p style=\"margin:0cm 0cm 8pt;font-size:11pt;font-family:Aptos, sans-serif;\"><b>Para: </b>Generar disponibilidad horaria </p><p style=\"margin:0cm 0cm 8pt;font-size:11pt;font-family:Aptos, sans-serif;\">&nbsp; </p><p style=\"margin:0cm 0cm 8pt;font-size:11pt;font-family:Aptos, sans-serif;\"> </p><p style=\"margin:0cm 0cm 8pt;font-size:11pt;font-family:Aptos, sans-serif;\"><b>Definición y comportamiento:&nbsp;</b> </p><p style=\"margin:0cm 0cm 8pt;font-size:11pt;font-family:Aptos, sans-serif;\">Desde la pantalla de Crear/Editar agendas, en la sección de bloque de programación, contaremos con un botón que indique “+Agregar bloque de programación” (<a href=\"https://xd.adobe.com/view/a4b6825b-0469-4a3f-9a1f-f8ea0c6d4b48-f1e5/screen/26a93b47-bab1-44ee-9cb1-d2db03c822a8\">pantalla1</a>). Al seleccionarlo, en el caso de tratarse de una agenda de tipo programada nos llevará a la pantalla de configuración de bloque de programación programada que cuenta con los siguientes datos (<a href=\"https://xd.adobe.com/view/a4b6825b-0469-4a3f-9a1f-f8ea0c6d4b48-f1e5/screen/f905ecca-23eb-49c7-9e6b-b6364ef58df3\">pantalla2</a>). </p><p style=\"margin:0cm 0cm 8pt;font-size:11pt;font-family:Aptos, sans-serif;\"><b><br></b> </p><p style=\"margin:0cm 0cm 8pt;font-size:11pt;font-family:Aptos, sans-serif;\"><b>Nombre de bloque de programación* </b>(campo de texto, 70 caracteres) </p><p style=\"margin:0cm 0cm 8pt;font-size:11pt;font-family:Aptos, sans-serif;\"><b>Selección Tipo de bloque de Programación *:&nbsp;</b>Con un radio button con las opciones de: &quot;<span style=\"font-family:Aptos, sans-serif;display:inline !important;\">Programación</span> Fija&quot; o &quot;Programación Variable&quot;<b>&nbsp;(en esta HU describiremos el comportamiento de la pantalla en el caso de haber seleccionado la opción duración fija.) </b>El proceso de creación de los slot&nbsp; &nbsp; </p><p style=\"margin:0cm 0cm 8pt;font-size:11pt;font-family:Aptos, sans-serif;\">Esto nos permitirá generar slots con una duración igual y fija. </p><div style=\"margin:0px 0cm 10.6667px;font-size:11pt;font-family:Aptos, sans-serif;\"><p style=\"box-sizing:border-box;margin:0cm 0cm 8pt;\"><b style=\"box-sizing:border-box;\">Fecha desde<b style=\"box-sizing:border-box;\">* (</b><span style=\"box-sizing:border-box;\">para indicar el inicio de la vigencia dd/mm/aaaa</span><b style=\"box-sizing:border-box;\">)</b></b> </p><p style=\"box-sizing:border-box;margin:0cm 0cm 8pt;\"><b style=\"box-sizing:border-box;\">Fecha hasta* (</b><span style=\"box-sizing:border-box;\">para indicar el fin de la vigencia,&nbsp;<span style=\"box-sizing:border-box;\"><span style=\"box-sizing:border-box;\">dd/mm/aaaa</span></span></span><b style=\"box-sizing:border-box;\">)</b> </p><p style=\"box-sizing:border-box;margin:0cm 0cm 8pt;\"><b style=\"box-sizing:border-box;\"><b>¿Atiende feriados?* (Si No&nbsp;</b><span style=\"font-weight:400;\">por default viene en false (No)</span><b>)</b><br></b> </p> </div><p style=\"margin:0cm 0cm 8pt;font-size:11pt;font-family:Aptos, sans-serif;\">Y los siguientes campos configuraran lo que será un slot fijo: </p><p style=\"margin:0cm 0cm 8pt;font-size:11pt;font-family:Aptos, sans-serif;\"><b>Seleccionar días * (</b>L, M, M, J,V, S,D botones de selección) </p><p style=\"margin:0cm 0cm 8pt;font-size:11pt;font-family:Aptos, sans-serif;\"><b>Horario desde * (</b>Horario en el que empezará el primer slot, HH:MM<b>)</b> </p><p style=\"margin:0cm 0cm 8pt;font-size:11pt;font-family:Aptos, sans-serif;\"><b>Horario hasta * (<span style=\"font-weight:400;display:inline !important;\">Horario en el que terminará el último slot, HH:MM</span><b style=\"box-sizing:border-box;\">)</b></b> </p><p style=\"margin:0cm 0cm 8pt;font-size:11pt;font-family:Aptos, sans-serif;\"><b style=\"font-weight:bold;box-sizing:border-box;\">Duración del turno * (</b><span style=\"box-sizing:border-box;\">Min que va a durar el slot, desplegable de 5,10,15,20,25,30,35,40,45,50,55,60 minutos</span><b style=\"font-weight:bold;box-sizing:border-box;\">)</b><br> </p><p style=\"margin:0cm 0cm 8pt;font-size:11pt;font-family:Aptos, sans-serif;\"><b>Lugar de atención* (</b>consultorios, box, area-sector información que va a venir, auto-complete<b>)</b> </p><p style=\"margin:0cm 0cm 8pt;font-size:11pt;font-family:Aptos, sans-serif;\"><b>Frecuencia *&nbsp;</b> </p><p style=\"margin:0cm 0cm 8pt;\"> </p><ul style=\"font-family:Aptos, sans-serif;font-size:11pt;\"><li>semanal:&nbsp;<span style=\"display:inline !important;\">Al seleccionar esta opción la configuración se repetirá todas las semanas que el bloque tenga vigencia</span> </li><li>quincenal: la configuración será de semanas alternas iniciando la semana que tenga la fecha desde del bloque </li><li>Dia de la semana por orden en el mes (Orden mensual): seleccionar el día de la semana por orden en el mes (Ej.: primer y tercer jueves del mes)(<a href=\"https://xd.adobe.com/view/a4b6825b-0469-4a3f-9a1f-f8ea0c6d4b48-f1e5/screen/87266170-f0a6-4354-84ac-372619f4b110\">Pantalla3</a>) </li> </ul> <p> </p><p style=\"margin:0cm 0cm 8pt;font-size:11pt;font-family:Aptos, sans-serif;\"><b>Nº Sobre turnos (</b>integer con cantidad de sobreturnos que aceptara cada día la programación que se está configurando<b>)</b> </p><p style=\"box-sizing:border-box;margin:0cm 0cm 8pt;font-size:11pt;font-family:Aptos, sans-serif;\"><span style=\"box-sizing:border-box;\">&nbsp;Debajo de la configuración del bloque de programación se encontrará la sección de gestión de prácticas (*) (<a href=\"https://dev.azure.com/SofreDigital/ODI/_workitems/edit/7029\" tabindex=0 style=\"box-sizing:border-box;border-radius:2px;cursor:pointer;outline:transparent;text-decoration:underline;transition:color 80ms cubic-bezier(0.165, 0.84, 0.44, 1), background 80ms linear;font-size:14px;\">Product Backlog Item 7029</a><span style=\"font-size:14px;display:inline !important;\">: Agregar prácticas médicas</span>) y luego tendremos la gestión de cupo para el bloque de programación (<a href=\"https://dev.azure.com/SofreDigital/ODI/_workitems/edit/11062\" tabindex=0 style=\"box-sizing:border-box;border-radius:2px;cursor:pointer;outline:transparent;text-decoration:underline;transition:color 80ms cubic-bezier(0.165, 0.84, 0.44, 1) 0s, background 80ms linear 0s;font-size:14px;\">Product Backlog Item 11062</a><span style=\"font-size:14px;display:inline !important;\">: Agregar reglas de cupo desde bloque de programación.</span>).</span> </p><p style=\"box-sizing:border-box;margin:0cm 0cm 8pt;font-size:11pt;font-family:Aptos, sans-serif;\"><span style=\"box-sizing:border-box;\"><b><b>(*)&nbsp;</b>datos de carácter obligatorio</b><br></span> </p><p style=\"box-sizing:border-box;margin:0cm 0cm 8pt;font-size:11pt;font-family:Aptos, sans-serif;\">Al final habrá dos botones: </p><p style=\"box-sizing:border-box;margin:0cm 0cm 8pt;font-size:11pt;font-family:Aptos, sans-serif;\">Cancelar: cancela la acción y vuelve a la pantalla de la agenda que se está creando/editando </p><p style=\"box-sizing:border-box;margin:0cm 0cm 8pt;font-size:11pt;font-family:Aptos, sans-serif;\">Guardar: se activará una vez completados todos los campos obligatorios, una vez seleccionado, se deberá mostrar un modal de confirmación (<a href=\"https://xd.adobe.com/view/a4b6825b-0469-4a3f-9a1f-f8ea0c6d4b48-f1e5/screen/3da9ec99-78cb-4cb0-922a-f1de6a019bc6\">Pantalla4</a>) al seleccionar &quot;SI, GUARDAR&quot; se guardará y generará la disponibilidad horaria configurada sino &quot;VOLVER&quot; nos llevará a la configuración del bloque de programación. </p><p style=\"margin:0cm 0cm 8pt;font-size:11pt;font-family:Aptos, sans-serif;\"><b>Pantallas</b> </p><div style=\"margin:0px 0cm 10.6667px;font-size:11pt;font-family:Aptos, sans-serif;\"><span style=\"display:inline !important;\"></span><a href=\"https://xd.adobe.com/view/a4b6825b-0469-4a3f-9a1f-f8ea0c6d4b48-f1e5/screen/26a93b47-bab1-44ee-9cb1-d2db03c822a8\" style=\"box-sizing:border-box;text-decoration:underline;\">pantalla1</a>&nbsp;Estructura de agenda </div><div style=\"margin:0px 0cm 10.6667px;font-size:11pt;font-family:Aptos, sans-serif;\"><span><a href=\"https://xd.adobe.com/view/a4b6825b-0469-4a3f-9a1f-f8ea0c6d4b48-f1e5/screen/f905ecca-23eb-49c7-9e6b-b6364ef58df3\" style=\"box-sizing:border-box;text-decoration:underline;\">pantalla2</a>&nbsp;</span><span>Agregar programación</span> </div><div style=\"margin:0px 0cm 10.6667px;font-size:11pt;font-family:Aptos, sans-serif;\"><span style=\"box-sizing:border-box;display:inline !important;\"></span><span style=\"box-sizing:border-box;display:inline !important;\"></span><a href=\"https://xd.adobe.com/view/a4b6825b-0469-4a3f-9a1f-f8ea0c6d4b48-f1e5/screen/87266170-f0a6-4354-84ac-372619f4b110\" style=\"box-sizing:border-box;text-decoration:underline;text-align:left;\">Pantalla3</a>&nbsp;<span style=\"box-sizing:border-box;display:inline !important;\">Agregar programación con frecuencia de orden mensual</span> </div><p style=\"margin:0cm 0cm 8pt;font-size:11pt;font-family:Aptos, sans-serif;\"><span style=\"display:inline !important;\"><a href=\"https://xd.adobe.com/view/a4b6825b-0469-4a3f-9a1f-f8ea0c6d4b48-f1e5/screen/3da9ec99-78cb-4cb0-922a-f1de6a019bc6\">Pantalla4</a> Modal de confirmación</span> </p><p style=\"margin:0cm 0cm 8pt;font-size:11pt;font-family:Aptos, sans-serif;\"> </p><div style=\"margin:0px 0cm 10.6667px;font-size:11pt;font-family:Aptos, sans-serif;\"><span><b style=\"box-sizing:border-box;font-size:14px;\"><b style=\"box-sizing:border-box;\">DER<a href=\"https://dbdiagram.io/d/Agendas-67a69d0b263d6cf9a070191b\" style=\"box-sizing:border-box;text-decoration:underline;cursor:pointer;\">&nbsp;Diagrama de agendas - dbdiagram.io</a></b></b></span> </div> </div>","acceptanceCriteria":"<p style=\"margin:0cm 0cm 8pt;\"><font face=\"Aptos, sans-serif\"><span style=\"font-size:14.6667px;\"><br></span></font> </p><p style=\"margin:0cm 0cm 8pt;\"> </p><p style=\"margin:0cm 0cm 8pt;\"> </p><p style=\"margin:0cm 0cm 8pt;\"> </p><p style=\"margin:0cm 0cm 8pt;\"> </p><p style=\"margin:0cm 0cm 8pt;\"> </p><ul style=\"font-family:Aptos, sans-serif;font-size:11pt;\"><li>Fecha inicio no puede ser previa a la fecha de vigencia de la agenda ni posterior a la fecha hasta de la vigencia de la agenda. </li><li>Fecha hasta no puede ser previa a la fecha inicio ni posterior a la fecha hasta de la vigencia de la agenda. </li><li>Validar que el rango de fecha y hora inicio con la fecha y hora hasta deben ser mayor o igual a la duración del slot. </li><li>Al dar guardar se guardará la configuración del bloque de programación y se generarán los slot en la agenda. Generando los slot fijos que se configuraron en el bloque. Dando como mensaje de confirmación de éxito &quot;Se agregó bloque de programación (Nombre de la agenda)&quot;. </li><li>Si no hay éxito en la creación/edición dará el mensaje &quot;No se pudo guardar. Verifique e intente mas tarde&quot; </li><li>Por default al crear un bloque de programación este debe quedar en estado activo.&nbsp; </li><li>Al seleccionar Orden mensual se desplegará un selector con 4 opciones&nbsp; Primera, segunda, tercera y cuarta. Solo se permitirá la selección de hasta dos opciones. </li> </ul> <p> </p><br>","taskCount":52,"tasks":[{"id":11293,"type":"Task","title":"Analisis funcional","state":"Done","assignedTo":"Natalia Gorriti","description":""},{"id":12849,"type":"Test Case","title":"Crear Bloque de Programación con Frecuencia Quincenal","state":"Ready","assignedTo":"Danieyse Egeria Berroteran Bernal","description":""},{"id":13292,"type":"Bug","title":"QA - El campo \"frecuencia\" en \"orden semanal\" rompe el diseño de la pantalla","state":"Done","assignedTo":"Danieyse Egeria Berroteran Bernal","description":""},{"id":12666,"type":"Task","title":"BE - EP frecuencia","state":"Done","assignedTo":"Lucas Ezequiel Ayala","description":""},{"id":13420,"type":"Bug","title":"QA - Al cargar un bloque con fecha desde a futura viene en estado INACTIVO","state":"Done","assignedTo":"Danieyse Egeria Berroteran Bernal","description":""},{"id":13752,"type":"Task","title":"BD - Rediseño modelo de datos","state":"Done","assignedTo":"Brian Ezequiel Agüero","description":"<div>A partir de reunión del área de BD con el área funcional se determino cambios en los datos que serán necesarios conservar. Por lo tanto se adaptó y mejoró el modelo, lo cual implicó eliminación de tablas y campos innecesarios y creación de campos más acordes a las necesidades funcionales.. </div>"},{"id":12586,"type":"Task","title":"BE - Code Review","state":"Done","assignedTo":"German Facundo Skrobak","description":""},{"id":13445,"type":"Bug","title":"QA - Al ingresar a crear Bloque aparece un chip de Activo","state":"Done","assignedTo":"Danieyse Egeria Berroteran Bernal","description":""},{"id":12598,"type":"Task","title":"QA - Ejecución de casos de prueba","state":"Done","assignedTo":"Danieyse Egeria Berroteran Bernal","description":""},{"id":13291,"type":"Bug","title":"QA - Superposición de la hora en los campos \"Hora desde\" y \"Hora hasta\"","state":"Done","assignedTo":"Danieyse Egeria Berroteran Bernal","description":""},{"id":12551,"type":"Task","title":"FE - Maquetado","state":"Done","assignedTo":"Romina Daiana Luzzi","description":""},{"id":13103,"type":"Task","title":"FE - Integracion de Endpoint Dias","state":"Done","assignedTo":"Romina Daiana Luzzi","description":""},{"id":13416,"type":"Bug","title":"QA - campos de \"Fecha desde\" y \"Fecha hasta\"","state":"Done","assignedTo":"Danieyse Egeria Berroteran Bernal","description":""},{"id":12850,"type":"Test Case","title":"Crear Bloque de Programación con Frecuencia Mensual","state":"Ready","assignedTo":"Danieyse Egeria Berroteran Bernal","description":""},{"id":13289,"type":"Bug","title":"QA - El campo “tipo de programación” difiere del mockup.","state":"Done","assignedTo":"Danieyse Egeria Berroteran Bernal","description":""},{"id":13290,"type":"Bug","title":"QA -  El nombre del campo \"Seleccionar tipo de programación\" no coincide con el mockup.","state":"Done","assignedTo":"Danieyse Egeria Berroteran Bernal","description":""},{"id":12552,"type":"Task","title":"FE - Integración maqueta","state":"Done","assignedTo":"Romina Daiana Luzzi","description":""},{"id":12853,"type":"Test Case","title":"Modificar Bloque de Programación Existente","state":"Ready","assignedTo":"Danieyse Egeria Berroteran Bernal","description":""},{"id":12597,"type":"Task","title":"QA - Creación casos de prueba","state":"Done","assignedTo":"Danieyse Egeria Berroteran Bernal","description":""},{"id":13003,"type":"Bug","title":"Error tabla t_frecuencias","state":"Done","assignedTo":"Lucas Ezequiel Ayala","description":""},{"id":13415,"type":"Bug","title":"QA - campo de \"frecuencia\" en \"Orden Mensual","state":"Done","assignedTo":"Danieyse Egeria Berroteran Bernal","description":""},{"id":12854,"type":"Test Case","title":"Eliminar Bloque de Programación","state":"Ready","assignedTo":"Danieyse Egeria Berroteran Bernal","description":""},{"id":13351,"type":"Bug","title":"QA - Error al cargar Selector de semana no esta guardando","state":"Done","assignedTo":"Lucas Ezequiel Ayala","description":""},{"id":12623,"type":"Task","title":"DIseño interfaz Lugares de atencion","state":"Done","assignedTo":"Brian Ezequiel Agüero","description":"<div><a href=\"#\" data-vss-mention=\"version:2.0,cb5ba784-c9ba-62ca-bf97-597a9b06f7ce\">@Maria Cecilia Pepa</a>&nbsp;<a href=\"#\" data-vss-mention=\"version:2.0,734b2817-2bae-68a6-a1d6-cc56f0170f5c\">@Martin Miguel Diaz Maffini</a>&nbsp;<a href=\"#\" data-vss-mention=\"version:2.0,aef4a389-9adb-6a9f-b0dc-08ce76016046\">@Melanie Garcia</a>&nbsp; Hay diferncias entre el mockup y la HU por lo que se nos paso el diseño de este endpoint. Porfa revisar! </div>"},{"id":12873,"type":"Task","title":"FE - Modal confirmacion de guardado","state":"Done","assignedTo":"Romina Daiana Luzzi","description":""},{"id":12626,"type":"Task","title":"Backend - EP lugares","state":"Done","assignedTo":"Lucas Ezequiel Ayala","description":""},{"id":13552,"type":"Bug","title":"QA - Error en la Validación del Campo Obligatorio al Cambiar de \"Frecuencia Semanal\" a \"Orden Mensual\".","state":"Done","assignedTo":"Danieyse Egeria Berroteran Bernal","description":""},{"id":13288,"type":"Bug","title":"QA - Textos en campos obligatorios.","state":"Done","assignedTo":"Danieyse Egeria Berroteran Bernal","description":""},{"id":12665,"type":"Task","title":"FE - Ingregracion de autocomplete lugares de atencion","state":"Done","assignedTo":"Marco Alex Brusa","description":""},{"id":12554,"type":"Task","title":"BE - Bloque de programacion","state":"Done","assignedTo":"Lucas Ezequiel Ayala","description":""},{"id":12757,"type":"Task","title":"FE - Intergrar EP semana","state":"Done","assignedTo":"Romina Daiana Luzzi","description":""},{"id":12851,"type":"Test Case","title":"Validación de Campos Obligatorios","state":"Ready","assignedTo":"Danieyse Egeria Berroteran Bernal","description":""},{"id":13471,"type":"Task","title":"BD - Desarrollo SP generación slots","state":"In Progress","assignedTo":"Eduardo Ynoub","description":""},{"id":23240,"type":"Bug","title":"QA -  Edicion de BPF - Error No Valida Fecha/Hora programacion Pasada","state":"Done","assignedTo":"Alfonso Oscar Koike","description":""},{"id":12903,"type":"Task","title":"FE - Fix hora","state":"Done","assignedTo":"Romina Daiana Luzzi","description":""},{"id":13127,"type":"Task","title":"Code Review","state":"Done","assignedTo":"Marco Alex Brusa","description":""},{"id":13417,"type":"Bug","title":"QA - Duración del turno y mensaje de error","state":"Done","assignedTo":"Danieyse Egeria Berroteran Bernal","description":""},{"id":13607,"type":"Bug","title":"QA - Error en la Visualización y Edición Manual de Fechas en Bloques de Programa