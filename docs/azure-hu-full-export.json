ption":""},{"id":23427,"type":"Task","title":"FE - Maquetado detalle Cobro","state":"Done","assignedTo":"Facundo Ezequiel Sergio","description":""},{"id":23494,"type":"Task","title":"QA-Ejecución de Casos de Prueba","state":"Done","assignedTo":"Hernan Alexis Gutierrez","description":""},{"id":23730,"type":"Task","title":"BE - Agregar id movimiento en ObtenerCargoByID","state":"Done","assignedTo":"Lucas Ezequiel Ayala","description":""}]},{"id":16093,"type":"Product Backlog Item","title":"Impresion de Ticket de Pago desde modulo Caja","state":"Done","areaPath":"ODI\\ODI Team Admision","iterationPath":"ODI\\R-01\\Sprint 30","assignedTo":"German Facundo Skrobak","description":"<p style=\"box-sizing:border-box;margin:0cm 0cm 0.0001pt;font-size:11pt;font-family:Calibri, sans-serif;text-align:justify;\"><b style=\"box-sizing:border-box;\"><span style=\"box-sizing:border-box;font-family:Arial, sans-serif;\">Como:&nbsp;</span></b><span style=\"box-sizing:border-box;font-family:Arial, sans-serif;\"><span style=\"box-sizing:border-box;font-family:Aptos, Aptos_EmbeddedFont, Aptos_MSFontService, sans-serif;text-align:start;display:inline !important;\">Cajero&nbsp;</span></span> </p><p style=\"box-sizing:border-box;margin:0cm 0cm 0.0001pt;font-size:11pt;font-family:Calibri, sans-serif;\"><b style=\"box-sizing:border-box;\"><span style=\"box-sizing:border-box;font-family:Arial, sans-serif;\">Quiero:<span style=\"box-sizing:border-box;\">&nbsp;</span></span></b><span style=\"box-sizing:border-box;font-family:Arial, sans-serif;\"><span style=\"box-sizing:border-box;\">&nbsp;Imprimir Ticket de pago</span><br style=\"box-sizing:border-box;\"><b style=\"box-sizing:border-box;\">Para:<span>&nbsp;</span></b><span style=\"box-sizing:border-box;\">Entregar el Ticket al cliente</span></span> </p><p style=\"box-sizing:border-box;margin:0cm 0cm 0.0001pt;font-size:11pt;font-family:Calibri, sans-serif;\"><span style=\"box-sizing:border-box;font-family:Arial, sans-serif;\"><span style=\"box-sizing:border-box;\"><br style=\"box-sizing:border-box;\"></span></span> </p><p style=\"box-sizing:border-box;margin:0cm 0cm 0.0001pt;font-size:11pt;font-family:Calibri, sans-serif;\"><span style=\"box-sizing:border-box;font-family:Arial, sans-serif;\"><span style=\"box-sizing:border-box;\"><span style=\"box-sizing:border-box;font-family:Calibri, sans-serif;text-align:justify;\"><span style=\"box-sizing:border-box;\"><span style=\"box-sizing:border-box;font-family:Arial, sans-serif;color:black;\"><u style=\"box-sizing:border-box;font-weight:bold;\">Descripción y comportamiento:</u>&nbsp;Una vez confirmado el pago en caja, se debe tener la opción de imprimir el Ticket  de pago para entregar al paciente.&nbsp;</span></span></span></span></span> </p><p style=\"box-sizing:border-box;margin:0cm 0cm 0.0001pt;font-size:11pt;font-family:Calibri, sans-serif;\"><span style=\"box-sizing:border-box;font-family:Arial, sans-serif;\"><span style=\"box-sizing:border-box;\"><span style=\"box-sizing:border-box;font-family:Calibri, sans-serif;text-align:justify;\"><span style=\"box-sizing:border-box;\"><span style=\"box-sizing:border-box;font-family:Arial, sans-serif;color:black;\"><br></span></span></span></span></span> </p><p style=\"box-sizing:border-box;margin:0cm 0cm 0.0001pt;font-size:11pt;font-family:Calibri, sans-serif;\"><span style=\"box-sizing:border-box;font-family:Arial, sans-serif;\"><span style=\"box-sizing:border-box;\"><span style=\"box-sizing:border-box;font-family:Calibri, sans-serif;text-align:justify;\"><span style=\"box-sizing:border-box;\"><span style=\"box-sizing:border-box;font-family:Arial, sans-serif;color:black;\"><span style=\"display:inline !important;\">En el comprobante se deben detallar los siguientes datos:</span><br></span></span></span></span></span> </p><ul><li><span style=\"font-family:Arial, sans-serif;text-align:justify;\">Logo del centro&nbsp;</span> </li><li><span style=\"font-family:Arial, sans-serif;text-align:justify;\"><span style=\"box-sizing:border-box;\">Fecha y hora de la compra.</span></span> </li><li><span style=\"font-family:Arial, sans-serif;text-align:justify;\">Estado del pago</span> </li><li><span style=\"font-family:Arial, sans-serif;text-align:justify;\"><span style=\"display:inline !important;\">Nombre o razón social del centro.&nbsp;</span><br></span> </li><li><span style=\"font-family:Arial, sans-serif;text-align:justify;\"><span style=\"display:inline !important;\">Servicio de atención</span></span> </li><li style=\"text-align:justify;\"><font face=\"Arial, sans-serif\">Datos de cliente (paciente)</font> </li><li><span style=\"font-family:Arial, sans-serif;text-align:justify;\">Descripción de los productos o servicios adquiridos con su importe. (prácticas + valor $)</span> </li><li><span style=\"font-family:Arial, sans-serif;text-align:justify;\">Total a pagar<br></span> </li><li><span style=\"font-family:Arial, sans-serif;text-align:justify;\">Medio de pago.&nbsp;</span> </li><li><span style=\"font-family:Arial, sans-serif;text-align:justify;\">Número de ticket o referencia para identificación<br></span> </li> </ul><div style=\"text-align:justify;\"><font face=\"Arial, sans-serif\">&nbsp;<span style=\"font-family:Arial, sans-serif;font-size:14.6667px;display:inline !important;\">Al finalizar el cobro al paciente, se debe tener la opción de imprimir el ticket de pago, ver mockup.</span><br></font> </div><div style=\"text-align:justify;\"><font face=\"Arial, sans-serif\"><span style=\"font-family:Arial, sans-serif;font-size:14.6667px;display:inline !important;\"><br></span></font> </div><div style=\"text-align:justify;\"><font face=\"Arial, sans-serif\"><span style=\"font-family:Arial, sans-serif;font-size:14.6667px;display:inline !important;\"><img src=\"https://dev.azure.com/SofreDigital/23856a9c-f820-4746-ac02-b8afbe8dd3e1/_apis/wit/attachments/eb807907-6edb-4574-b47e-3f3235a5c7ac?fileName=Imprimir%20Compobante%20de%20pago.jpg\" alt=Image><br></span></font> </div><div style=\"text-align:justify;\"><font face=\"Arial, sans-serif\"><span style=\"font-family:Arial, sans-serif;font-size:14.6667px;display:inline !important;\"><br></span></font> </div><div style=\"text-align:justify;\"><span style=\"font-family:Arial, sans-serif;font-size:14.6667px;display:inline !important;\">Al imprimir se debe generar un reporte del pago en formato pdf con las dimensiones de una impresora térmica. Ver mockup</span><br> </div><div style=\"text-align:justify;\"><span style=\"font-family:Arial, sans-serif;font-size:14.6667px;display:inline !important;\"><br></span> </div><div style=\"text-align:justify;\"><span style=\"font-family:Arial, sans-serif;font-size:14.6667px;display:inline !important;\"><br></span> </div><div style=\"text-align:justify;\"><span style=\"font-family:Arial, sans-serif;font-size:14.6667px;display:inline !important;\"><img src=\"https://dev.azure.com/SofreDigital/23856a9c-f820-4746-ac02-b8afbe8dd3e1/_apis/wit/attachments/a0681731-a615-4fd0-b922-3b65f90fbc56?fileName=%28DAFT%20Ticket%29.jpg\" alt=Image style=\"width:309px;\" width=309 height=524><br></span> </div><div style=\"text-align:justify;\"><span style=\"font-family:Arial, sans-serif;font-size:14.6667px;display:inline !important;\"><br></span> </div><div style=\"text-align:justify;\"><span style=\"font-family:Arial, sans-serif;font-size:14.6667px;display:inline !important;\">Datos de configuración de impresión:</span> </div><div style=\"text-align:justify;\"><ul><li><span style=\"font-family:Arial, sans-serif;font-size:14.6667px;display:inline !important;\">El ticket debe imprimirse en papel térmico con un ancho de 58 mm (2.28 pulgadas) o 80 mm (3.15 pulgadas) (según modelo de impresora).</span> </li><li><span style=\"font-family:Arial, sans-serif;font-size:14.6667px;display:inline !important;\">El contenido del ticket debe estar ajustado al ancho definido, sin desbordamientos ni cortes de texto.<br></span> </li><li><span style=\"font-family:Arial, sans-serif;font-size:14.6667px;display:inline !important;\">La longitud del ticket debe ser dinámica, dependiendo del contenido (cantidad de productos, totales, etc.).<br></span> </li><li><span style=\"font-family:Arial, sans-serif;font-size:14.6667px;display:inline !important;\"> Se deben respetar márgenes mínimos para evitar cortes al borde del papel.</span> </li> </ul> </div><div style=\"text-align:justify;\"> </div><div style=\"text-align:justify;\"><span style=\"font-family:Arial, sans-serif;font-size:14.6667px;display:inline !important;\">En caso de no imprimir en el momento del pago, se debe poder imprimir desde Visualizar estado pagado HU&nbsp;<span style=\"display:inline !important;\">&nbsp;</span><span style=\"box-sizing:border-box;font-size:14px;display:inline !important;\">(</span><a href=\"https://dev.azure.com/SofreDigital/ODI/_workitems/edit/16091\" tabindex=0 style=\"box-sizing:border-box;color:rgb(0, 90, 158);text-decoration:none !important;cursor:pointer;border-radius:2px;outline:transparent;transition:color 80ms cubic-bezier(0.165, 0.84, 0.44, 1), background 80ms linear;font-size:12px;text-align:start;\">ITEM 16091</a><span style=\"box-sizing:border-box;font-size:14px;display:inline !important;\">)&nbsp;</span> como se muestra a continuación:<br></span> </div><div style=\"text-align:justify;\"><span style=\"font-family:Arial, sans-serif;font-size:14.6667px;display:inline !important;\"><br></span> </div><div style=\"text-align:justify;\"><span style=\"font-family:Arial, sans-serif;font-size:14.6667px;display:inline !important;\"><img src=\"https://dev.azure.com/SofreDigital/23856a9c-f820-4746-ac02-b8afbe8dd3e1/_apis/wit/attachments/4144e507-be83-4c70-8a06-f646b1db6ba0?fileName=image.png\" alt=Image><br></span> </div><div style=\"text-align:justify;\"><br> </div><div style=\"text-align:justify;\"><br> </div><div style=\"text-align:justify;\">Mockup impresión desde &quot;éxito&quot;: </div><div style=\"text-align:justify;\"><a href=\"https://xd.adobe.com/view/824318ca-1996-4f68-855d-750bb0711363-d710/\">https://xd.adobe.com/view/824318ca-1996-4f68-855d-750bb0711363-d710/</a><br><br><span style=\"display:inline !important;\">Mockup impresión desde <i>consulta/detalle de operación previa&nbsp;</i>&quot;imprimir comprobante&quot; (<a href=\"https://dev.azure.com/SofreDigital/ODI/_workitems/edit/16091\" tabindex=0 style=\"box-sizing:border-box;color:rgb(0, 90, 158);text-decoration:none !important;cursor:pointer;border-radius:2px;outline:transparent;transition:color 80ms cubic-bezier(0.165, 0.84, 0.44, 1), background 80ms linear;font-size:12px;text-align:start;\">ITEM 16091</a>):<br><a href=\"https://xd.adobe.com/view/eec72ba8-819f-4a09-934c-ab65fb8d5599-bb94/\">https://xd.adobe.com/view/eec72ba8-819f-4a09-934c-ab65fb8d5599-bb94/</a><br></span><br> </div>","acceptanceCriteria":"<div><ul><li>Se debe permitir la impresión del reporte o comprobante de pago al finalizar el pago.&nbsp; </li><li>En caso de no imprimir en el momento, se debe poder imprimir desde&nbsp;Visualizar estado pagado&nbsp;<a href=\"https://dev.azure.com/SofreDigital/ODI/_workitems/edit/16091\" tabindex=0 style=\"box-sizing:border-box;color:rgb(0, 90, 158);border-radius:2px;cursor:pointer;outline:transparent;text-decoration:none !important;transition:color 80ms cubic-bezier(0.165, 0.84, 0.44, 1), background 80ms linear;font-size:12px;text-align:start;\"><span>&nbsp;</span>ITEM 16091</a> </li> </ul> </div>","taskCount":41,"tasks":[{"id":23459,"type":"Test Case","title":"QA - Validar la Fecha y hora de la compra en el ticket ","state":"Ready","assignedTo":"Cristina Alejandra Schroeder","description":""},{"id":23457,"type":"Test Case","title":"QA - Validar el botón \"VOLVER\" del modal \"Se generó el pago. ¿Deseas imprimir el comprobante?\"","state":"Ready","assignedTo":"Cristina Alejandra Schroeder","description":""},{"id":23455,"type":"Test Case","title":"QA - Validar el modal \"Se generó el pago. ¿Deseas imprimir el comprobante?\"","state":"Ready","assignedTo":"Cristina Alejandra Schroeder","description":""},{"id":23464,"type":"Test Case","title":"QA - Validar Descripción de los productos o servicios adquiridos con su importe en el ticket ","state":"Ready","assignedTo":"Cristina Alejandra Schroeder","description":""},{"id":24131,"type":"Bug","title":"QA - Impresión de Ticket de Pago desde modulo Caja - Ticket - No se observa el número de ticket","state":"Done","assignedTo":"Cristina Alejandra Schroeder","description":""},{"id":24034,"type":"Bug","title":"QA - Impresión de Ticket de Pago desde modulo Caja - Botón \"VOLVER\" en minúscula, debería estar en mayúscula","state":"Done","assignedTo":"Cristina Alejandra Schroeder","description":""},{"id":23590,"type":"Task","title":"Code Review","state":"Done","assignedTo":"Marco Alex Brusa","description":""},{"id":16128,"type":"Task","title":"Análisis, diseño y escritura funcional","state":"Done","assignedTo":"Geroan Antonio Cadenas Alvarez","description":""},{"id":23468,"type":"Test Case","title":"QA - Validar que al imprimir se genere un reporte del pago en formato pdf ","state":"Ready","assignedTo":"Cristina Alejandra Schroeder","description":""},{"id":23299,"type":"Task","title":"QA - Diseño casos de prueba","state":"Done","assignedTo":"Cristina Alejandra Schroeder","description":"<div><a href=\"https://sofredigital.sharepoint.com/:x:/s/GrupoBASA/EQqMQgcchh5FgFUBFBBy0fYB42dIYr0CJHa3JiQQzVpt0Q?e=hXUrrO\">16093 - Impresion de Ticket de Pago desde modulo Caja.xlsx</a><br> </div>"},{"id":24061,"type":"Bug","title":"QA - Impresión de Ticket de Pago desde modulo Caja – El formato del centro difiere del mock up y falta incluir el ícono de localización","state":"Done","assignedTo":"Cristina Alejandra Schroeder","description":""},{"id":23469,"type":"Test Case","title":"QA - Validar que el reporte de pago se imprima en papel térmico","state":"Ready","assignedTo":"Cristina Alejandra Schroeder","description":""},{"id":23456,"type":"Test Case","title":"QA - Validar el botón \"SI, IMPRIMIR\" del modal \"Se generó el pa