# ============================================
# VitalFlow HIS — variables de entorno requeridas
# Copie este archivo como .env y complete los valores.
# ============================================

# PostgreSQL (requerido)
POSTGRES_DB=vitalflow_his
POSTGRES_USER=CHANGE_ME_DB_USER
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD
POSTGRES_PORT=5433

# Redis (requerido — min 8 caracteres)
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# JWT (requerido — min 32 caracteres)
JWT_SIGNING_KEY=CHANGE_ME_JWT_SIGNING_KEY_WITH_32_CHARS_MIN

# Portal Backend — credenciales para comunicarse con HIS Backend (requerido)
HIS_API_USERNAME=admin
HIS_API_PASSWORD=CHANGE_ME_HIS_API_PASSWORD

# Portal Secrets (requerido — cambiar en produccion)
JWT_SECRET=CHANGE_ME_PORTAL_JWT_SECRET
NEXTAUTH_SECRET=CHANGE_ME_NEXTAUTH_SECRET

# Frontend dev (vite.config.ts)
VITE_API_BACKEND_URL=http://localhost:3001

# SMTP (opcional — dejar vacio para desactivar correos)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=noreply@vitalflow.com
SMTP_FROM_NAME=VitalFlow HIS

# Conv-Fact (opcional — perfil: conv-fact)
CONV_FACT_DB_PASSWORD=CHANGE_ME_CONV_FACT_PASSWORD

# pgAdmin (opcional — perfil: debug)
PGADMIN_EMAIL=admin@vitalflow.dev
PGADMIN_PASSWORD=CHANGE_ME_PGADMIN_PASSWORD
